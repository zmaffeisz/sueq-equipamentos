# ─────────────────────────────────────────────────────────────────────────────
# dashboard-emendas — variáveis de ambiente (referência)
#
# IMPORTANTE: hoje o app NÃO lê variáveis de ambiente. As credenciais do Supabase
# estão hardcoded em index.html, login.html e cadastro.html (por ser um app estático
# sem etapa de build). Este arquivo documenta as variáveis relevantes e serve de base
# caso a configuração passe a ser injetada (ex.: via config.js ou build).
# ─────────────────────────────────────────────────────────────────────────────

# URL do projeto Supabase (pública)
SUPABASE_URL=https://djtwoesmgeetnrztyvzw.supabase.co

# Chave PUBLISHABLE / ANON (segura para o cliente — protegida por RLS)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# NUNCA exponha a service_role key no frontend. Use somente em scripts/servidores
# de confiança (migrações, jobs administrativos).
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=__nunca_no_cliente__

# ─────────────────────────────────────────────────────────────────────────────
# Supabase LOCAL (opcional — stack de desenvolvimento, ver supabase/config.toml).
# O app em runtime NÃO aponta para o local; estas portas são apenas do CLI local.
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_LOCAL_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# SUPABASE_LOCAL_API_URL=http://127.0.0.1:54321
# SUPABASE_LOCAL_STUDIO_URL=http://127.0.0.1:54323

# Chaves usadas por integrações do Supabase local (ver config.toml), se aplicável:
# OPENAI_API_KEY=
# S3_HOST=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
